# act runner image mappings
# catthehacker images are lightweight GitHub Actions-compatible Ubuntu images.
# Full image list: https://github.com/catthehacker/docker_images
-P ubuntu-latest=catthehacker/ubuntu:act-22.04
-P ubuntu-22.04=catthehacker/ubuntu:act-22.04

# macOS and Windows runners cannot run natively in Docker, but mapping them to an
# Ubuntu image lets the test matrix run locally. Java tests pass on all three since
# they don't depend on OS-specific behavior.
-P macos-latest=catthehacker/ubuntu:act-22.04
-P windows-latest=catthehacker/ubuntu:act-22.04
